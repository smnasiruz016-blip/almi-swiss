// AlmiSwiss data model. The shared engine foundation (auth, billing, AI cost ledger)
// is common to the AlmiWorld language products. The practice layer is an ITEM-BANK: a
// single SwissItem ↔ SwissAttempt pair carries every task type via a typed `payload`
// Json, instead of one model per skill. Scoring is hybrid — deterministic for
// objective modules (Reading, Listening, and the local-knowledge MCQ), AI
// trait-feedback for productive modules (Writing, Speaking) — and is reported as an
// honest per-skill readiness band, never a fabricated composite or an official result.
//
// Structural note 1: an item belongs to exactly ONE exam, so `exam` lives ON THE ITEM
// and is the primary filter, alongside `track` for the goal funnel.
//
// Structural note 2 — THE LANGUAGE AXIS, which does not exist in the Nordic products
// this was forked from. They each have one national language, so (exam, skill)
// identified an item. Switzerland has three, and the candidate's CANTON decides which
// applies. So `language` is on the item, on the session, and FIRST in the indexes.
// Drop it and a French candidate is served German items — a query that returns the
// wrong language throws nothing and looks like content.
//
// All content is original; results are practice estimates, never an official result
// from SEM, a canton, or a fide test centre — candidates confirm the real requirement
// with their cantonal migration authority.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Locale {
  EN
  UR
  AR
  HI
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  passwordHash String
  locale       Locale  @default(EN)
  countryCode  String?
  referralCode String  @unique @default(cuid())

  // Email verification — required before paid feature access.
  emailVerified               DateTime?
  emailVerificationTokenHash  String?   @unique
  emailVerificationExpiresAt  DateTime?
  emailVerificationLastSentAt DateTime?

  // Stripe subscription state — webhook keeps this in lockstep with Stripe.
  stripeCustomerId              String?          @unique
  stripeSubscriptionId          String?          @unique
  subscriptionStatus            String?
  subscriptionPlan              String?
  subscriptionCurrentPeriodEnd  DateTime?
  subscriptionCancelAtPeriodEnd Boolean          @default(false)
  trialEndsAt                   DateTime?
  subscriptionTier              SubscriptionTier @default(FREE)

  // Comp Pro access — admin-granted, no Stripe. isProActive()/hasPaidAccess()
  // short-circuit true while compProUntil is in the future, bypassing BOTH the
  // subscription check AND email verification. AlmiSwiss full Pro = AI feedback on
  // Writing + Speaking + the full per-exam mock.
  compProUntil  DateTime?
  compGrantedAt DateTime?
  compGrantedBy String?
  compReason    String?

  // Which exam the user is preparing for (fide / a recognised certificate / local
  // knowledge). Drives the default mock and which practice content is surfaced.
  // Null = not chosen.
  targetExam SwissExam?
  // And in WHICH national language — inseparable from targetExam, because "fide" alone
  // does not identify a test. Null = not chosen.
  targetLanguage SwissLanguage?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  svAttempts          SwissAttempt[]
  svSessions          SwissSession[]
  reviews             Review[]

  @@index([email])
  @@index([referralCode])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([compProUntil])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model ProcessedWebhook {
  id          String   @id
  eventType   String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model EarlyAccess {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())

  @@index([email])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  text      String   @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([approved, createdAt])
}

model AICostLedger {
  id               String   @id @default(cuid())
  timestamp        DateTime @default(now())
  userId           String?
  feature          String
  model            String
  inputTokens      Int
  outputTokens     Int
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  costCents        Int
  success          Boolean  @default(true)
  errorMessage     String?

  @@index([timestamp(sort: Desc)])
  @@index([userId, timestamp])
  @@index([feature, timestamp])
}


// ===================== Swiss practice item-bank =====================
// AlmiSwiss covers FIVE goal tracks via ONE item-bank, across the national languages
// in SHIPPING_LANGUAGES (see src/lib/ch/types.ts).
//
// FACT BASE — the tiers differ, and the header says which is which BECAUSE a fork
// flattens them. Full provenance in src/lib/ch/registry.ts; re-check before editing.
//   • VERIFIED AT SEM: naturalisation requires B1 SPOKEN + A2 WRITTEN in ONE national
//     language. ⚠️ That figure is SEM's for the FACILITATED (married) route, which SEM
//     itself decides. For ORDINARY naturalisation the CANTON AND COMMUNE decide and may
//     ask more. Never blur the two into one "Swiss requirement".
//   • VERIFIED AT SEM: fide is the Swiss test and issues the fide language passport;
//     SEM-recognised certificates (telc/Goethe · DELF/TCF · CELI) are accepted too.
//   • FOUNDER-SUPPLIED, SECONDARY-SOURCED — NOT confirmed at SEM: the C permit levels
//     (ordinary 10yr = A2 spoken/A1 written; early 5yr = B1 spoken/A1 written). SEM's
//     CEFR table is an image and its factsheet PDFs 403 automated fetches. Shown in the
//     product with its provenance attached, not asserted as verified fact.
//   • THERE IS NO NATIONAL CIVICS TEST. Verified by its ABSENCE from SEM: cantons and
//     communes differ — some use a test, some an interview, some neither. CANTON_CIVIC
//     is PRACTICE, never an exam. Do not add a national civics exam, do not invent a
//     canton's questions or format, and never state or imply a pass mark. An absence is
//     the hardest thing to keep true across a fork: nothing breaks if we invent one.
//
// NOT MODELLED, DELIBERATELY: Romansh (a national language, but rarely the language of
// a naturalisation procedure — omitted rather than filled with invented content).
//
// One SwissItem/SwissAttempt pair serves every task type via a typed `payload` Json.
// All content is original; results are per-skill readiness estimates — never an
// official result. Confirm current requirements with the cantonal migration authority.

enum SwissTrack {
  CITIZENSHIP // fide at the federal minimum: B1 spoken + A2 written (lead)
  C_PERMIT // fide at the permit levels — lower than citizenship, and route-dependent
  CERTIFICATE // SEM-recognised certificates: telc/Goethe · DELF/TCF · CELI
  GETTING_STARTED // A1–A2 everyday language — groundwork, not an exam
  CANTON_CIVIC // canton-dependent local knowledge. NOT a national test — none exists.
}

// Exam axis. fide (the Swiss test) + the SEM-recognised certificate families, plus
// canton-dependent local-knowledge practice. NOTE what is absent: no national civics
// exam, because Switzerland has none. See the fact base above.
enum SwissExam {
  FIDE // the Swiss scenario-based test — issues the fide language passport (lead)
  TELC_GOETHE // SEM-recognised German certificates
  DELF_TCF // SEM-recognised French certificates
  CELI // SEM-recognised Italian certificates
  CANTON_CIVIC // local-knowledge PRACTICE. Not an exam: Switzerland has no national civics test.
}

// Switzerland's relevant national languages. This axis does not exist in the Nordic
// products this schema was forked from — they each have ONE national language, so
// (exam, skill) identified an item. Here it does not: fide in German and fide in
// French are different tests, and which one applies is decided by the candidate's
// CANTON. Every item and session is therefore language-scoped.
// Romansh is a national language but is rarely the language of a naturalisation
// procedure — omitted deliberately rather than modelled with invented content.
enum SwissLanguage {
  DE
  FR
  IT
}

enum SwissSkill {
  READING // objective
  LISTENING // objective
  WRITING // AI-graded
  SPEAKING // AI-graded
  KNOWLEDGE // local-knowledge MCQ (objective) — used by CANTON_CIVIC only
}

enum SwissTaskType {
  MCQ_SINGLE // objective single-answer multiple choice (Reading/Listening)
  MATCHING // objective matching
  CLOZE // objective gap-fill (option-per-gap)
  ORDERING // objective sequence
  TRUE_FALSE // objective true/false/not-stated
  WRITING_PROMPT // productive writing (criteria + char band)
  SPEAKING_PROMPT // productive speaking (criteria)
}

enum SwissDifficulty {
  FOUNDATION
  CORE
  STRETCH
}

enum SwissAttemptStatus {
  PENDING
  SCORED // objective auto-graded
  EVALUATED // productive AI-graded
  FAILED
}

enum SwissSessionMode {
  PRACTICE
  MOCK
}

enum SwissSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model SwissItem {
  id         String          @id @default(cuid())
  // Which national language this item is SET IN. Not a display preference: an item
  // is only ever valid for candidates whose canton uses this language.
  language   SwissLanguage
  track      SwissTrack
  exam       SwissExam
  skill      SwissSkill
  taskType   SwissTaskType
  difficulty SwissDifficulty @default(CORE)
  title      String
  // Instruction / stem shown to the candidate (NL).
  prompt     String
  // Task-specific structure: objective → { options, passage, transcript, answerKey };
  // productive → { criteria[], charBand, stimulus }. Validated in src/lib/ch/types.
  payload    Json
  // Objective answer key (null for productive/AI tasks).
  answer     Json?
  // Objective max points for this item (0 for productive; readiness is qualitative).
  maxPoints  Int             @default(0)
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  attempts   SwissAttempt[]

  @@index([language, track, exam, skill, active])
  @@index([language, exam, skill])
}

model SwissAttempt {
  id        String             @id @default(cuid())
  userId    String
  itemId    String
  sessionId String?
  status    SwissAttemptStatus @default(PENDING)
  // User response: objective → selected answer(s); productive → { text } or { audioKey }.
  response  Json?
  // Objective scoring.
  points    Int?
  maxPoints Int?
  // Productive AI trait feedback: { traits[], summary, estimate }.
  aiFeedback Json?
  // Honest readout: per-skill "CLEAR"|"BORDERLINE"|"BELOW" — never an official result.
  readiness String?
  createdAt   DateTime  @default(now())
  submittedAt DateTime?

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  item    SwissItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  session SwissSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([itemId])
  @@index([sessionId])
}

model SwissSession {
  id        String             @id @default(cuid())
  userId    String
  language  SwissLanguage
  track     SwissTrack
  exam      SwissExam
  mode      SwissSessionMode   @default(PRACTICE)
  status    SwissSessionStatus @default(IN_PROGRESS)
  // Aggregate readout: { perSkill: {skill: {points,max,readiness}}, overall }.
  aggregate Json?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts SwissAttempt[]

  @@index([userId, createdAt])
}
