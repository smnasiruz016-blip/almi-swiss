// AlmiSwedish data model. The shared engine foundation (auth, billing, AI cost
// ledger) is common to the AlmiWorld language products. The practice layer is an
// ITEM-BANK: a single SwedishItem ↔ SwedishAttempt pair carries every task type via
// a typed `payload` Json, instead of one model per skill. Scoring is hybrid —
// deterministic for objective modules (Läsförståelse + Hörförståelse + the society
// MCQ), AI trait-feedback for productive modules (Skriftlig framställning + Muntlig)
// — and is reported as an honest per-skill readiness band, never a fabricated
// composite or an official result.
//
// Structural note: an item belongs to exactly ONE exam (SFI A–B reading content is
// not Tisus reading content), so `exam` lives ON THE ITEM and is the primary filter,
// alongside `track` for the goal funnel.
//
// All content is original Swedish, never copied from UHR, Stockholms universitet or
// Skolverket material; results are practice estimates — candidates confirm the real
// requirement with UHR / Migrationsverket / their university.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Locale {
  EN
  UR
  AR
  HI
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  passwordHash String
  locale       Locale  @default(EN)
  countryCode  String?
  referralCode String  @unique @default(cuid())

  // Email verification — required before paid feature access.
  emailVerified               DateTime?
  emailVerificationTokenHash  String?   @unique
  emailVerificationExpiresAt  DateTime?
  emailVerificationLastSentAt DateTime?

  // Stripe subscription state — webhook keeps this in lockstep with Stripe.
  stripeCustomerId              String?          @unique
  stripeSubscriptionId          String?          @unique
  subscriptionStatus            String?
  subscriptionPlan              String?
  subscriptionCurrentPeriodEnd  DateTime?
  subscriptionCancelAtPeriodEnd Boolean          @default(false)
  trialEndsAt                   DateTime?
  subscriptionTier              SubscriptionTier @default(FREE)

  // Comp Pro access — admin-granted, no Stripe. isProActive()/hasPaidAccess()
  // short-circuit true while compProUntil is in the future, bypassing BOTH the
  // subscription check AND email verification. AlmiSwedish full Pro = AI feedback
  // on Skriftlig framställning + Muntlig + the full per-exam mock.
  compProUntil  DateTime?
  compGrantedAt DateTime?
  compGrantedBy String?
  compReason    String?

  // Which Swedish exam the user is preparing for (SFI ladder / Tisus / Medborgarskapsprovet).
  // Drives the default mock and which practice content is surfaced. Null = not chosen.
  targetExam SwedishExam?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  svAttempts          SwedishAttempt[]
  svSessions          SwedishSession[]
  reviews             Review[]

  @@index([email])
  @@index([referralCode])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([compProUntil])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model ProcessedWebhook {
  id          String   @id
  eventType   String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model EarlyAccess {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())

  @@index([email])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  text      String   @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([approved, createdAt])
}

model AICostLedger {
  id               String   @id @default(cuid())
  timestamp        DateTime @default(now())
  userId           String?
  feature          String
  model            String
  inputTokens      Int
  outputTokens     Int
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  costCents        Int
  success          Boolean  @default(true)
  errorMessage     String?

  @@index([timestamp(sort: Desc)])
  @@index([userId, timestamp])
  @@index([feature, timestamp])
}


// ===================== Swedish practice item-bank =====================
// AlmiSwedish covers FOUR goal tracks via ONE item-bank:
//   • Medborgarskapsprovet — Sweden's NEW citizenship test. Under the law in force
//     6 June 2026, applicants aged 16–66 must show knowledge of Swedish society and
//     Swedish. UHR (Universitets- och högskolerådet) develops, administers and marks
//     it; Migrationsverket assesses applications and instructs applicants to register.
//     Only the SOCIETY component exists: UHR's first sitting is 15 Aug 2026 and is an
//     *utprövningsprov* (pilot), free of charge. UHR states the format provisionally
//     as ~60 four-option multiple-choice questions in 90 minutes, in Swedish, on paper,
//     drawn from its own study material "Sverige i fokus". THE PASS MARK IS NOT
//     PUBLISHED — never state or imply one.
//   • The SWEDISH LANGUAGE component of the citizenship test is NOT modelled here.
//     UHR indicates it cannot be ready before autumn 2028 and no CEFR level has been
//     set. We do not ship practice for a test with no published spec. Do not add a
//     MEDBORGARSKAPSPROV language exam until UHR publishes one.
//   • Tisus (Test i svenska för universitets- och högskolestudier) — the established
//     ≈C1 proficiency test for Swedish-taught university admission, run by Stockholms
//     universitet.
//   • SFI (Svenska för invandrare) courses A–D and a general CEFR ladder. Skolverket
//     maps SFI A/B ≈ A1–A2 and C/D ≈ A2–B1+; the SFI scale is NOT itself CEFR, so the
//     mapping is stated as approximate.
// Swedex is deliberately absent: it can no longer be taken after 31 Dec 2026.
// One SwedishItem/SwedishAttempt pair serves every task type via a typed `payload`
// Json. All content is original Swedish; results are per-skill readiness estimates —
// never an official UHR result. Confirm current requirements with UHR/Migrationsverket.

enum SwedishTrack {
  CITIZENSHIP // Medborgarskapsprovet — society component (lead)
  UNIVERSITY // Tisus (≈C1)
  GETTING_STARTED // SFI courses A–B (≈A1–A2)
  PROFICIENCY // SFI C–D + general Swedish CEFR ladder
}

// Exam axis. The Swedish language ladder (SFI A–B, SFI C–D, general B1–B2, Tisus)
// plus the one society knowledge test (Medborgarskapsprovet).
enum SwedishExam {
  SFI_AB // SFI courses A–B — ≈A1–A2 (getting started)
  SFI_CD // SFI courses C–D — ≈A2–B1+ (the common SFI exit)
  SVENSKA_B1B2 // General Swedish — B1–B2 (CEFR ladder)
  TISUS // Tisus — ≈C1 (university admission)
  MEDBORGARSKAPSPROV // Citizenship society knowledge test (lead)
}

enum SwedishSkill {
  READING // Läsförståelse (objective)
  LISTENING // Hörförståelse (objective)
  WRITING // Skriftlig framställning (AI-graded)
  SPEAKING // Muntlig (AI-graded)
  KNOWLEDGE // Samhällskunskap — society knowledge MCQ (objective)
}

enum SwedishTaskType {
  MCQ_SINGLE // objective single-answer multiple choice (Reading/Listening)
  MATCHING // objective matching
  CLOZE // objective gap-fill (option-per-gap)
  ORDERING // objective sequence
  TRUE_FALSE // objective true/false/not-stated
  WRITING_PROMPT // productive writing (criteria + char band)
  SPEAKING_PROMPT // productive speaking (criteria)
}

enum SwedishDifficulty {
  FOUNDATION
  CORE
  STRETCH
}

enum SwedishAttemptStatus {
  PENDING
  SCORED // objective auto-graded
  EVALUATED // productive AI-graded
  FAILED
}

enum SwedishSessionMode {
  PRACTICE
  MOCK
}

enum SwedishSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model SwedishItem {
  id         String          @id @default(cuid())
  track      SwedishTrack
  exam       SwedishExam
  skill      SwedishSkill
  taskType   SwedishTaskType
  difficulty SwedishDifficulty @default(CORE)
  title      String
  // Instruction / stem shown to the candidate (NL).
  prompt     String
  // Task-specific structure: objective → { options, passage, transcript, answerKey };
  // productive → { criteria[], charBand, stimulus }. Validated in src/lib/sv/types.
  payload    Json
  // Objective answer key (null for productive/AI tasks).
  answer     Json?
  // Objective max points for this item (0 for productive; readiness is qualitative).
  maxPoints  Int             @default(0)
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  attempts   SwedishAttempt[]

  @@index([track, exam, skill, active])
  @@index([exam, skill])
}

model SwedishAttempt {
  id        String             @id @default(cuid())
  userId    String
  itemId    String
  sessionId String?
  status    SwedishAttemptStatus @default(PENDING)
  // User response: objective → selected answer(s); productive → { text } or { audioKey }.
  response  Json?
  // Objective scoring.
  points    Int?
  maxPoints Int?
  // Productive AI trait feedback: { traits[], summary, estimate }.
  aiFeedback Json?
  // Honest readout: per-skill "CLEAR"|"BORDERLINE"|"BELOW" — never an official result.
  readiness String?
  createdAt   DateTime  @default(now())
  submittedAt DateTime?

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  item    SwedishItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  session SwedishSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([itemId])
  @@index([sessionId])
}

model SwedishSession {
  id        String             @id @default(cuid())
  userId    String
  track     SwedishTrack
  exam      SwedishExam
  mode      SwedishSessionMode   @default(PRACTICE)
  status    SwedishSessionStatus @default(IN_PROGRESS)
  // Aggregate readout: { perSkill: {skill: {points,max,readiness}}, overall }.
  aggregate Json?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts SwedishAttempt[]

  @@index([userId, createdAt])
}
